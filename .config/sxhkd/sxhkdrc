# --------- PULSEMIXER (AUDIO MANAGER) ---------

# open pulsemixer
ctrl + alt + v
    bspc rule -a \* -o state=floating ; pavucontrol # ghostty -e /bin/zsh -c pulsemixer

# pulsemixer volume UP (+5)
super + F3
	pulsemixer --change-volume +5

# pulsemixer volume DOWN (-5)
super + F2
	pulsemixer --change-volume -5

# pulsemixer volume MUTE (0)
super + F5
	pulsemixer --toggle-mute


# --------- DUNST (NOTIFICATION MANAGER) ---------

# close all notifications
    
# notifications history
super + shift + Escape
    dunstctl history-pop


# ----------------------- BSPWM HOTKEYS -----------------------

# system shutdown
super + alt + s
    systemctl poweroff

# system restart
super + alt + r
    reboot

# quit/restart bspwm
super + alt + {q,r}
	bspc {quit,wm -r}

# close and kill
super + q
	bspc node -c

# alternate between the tiled and monocle layout
super + o
	bspc desktop -l next

# send the newest marked node to the newest preselected node
super + y
	bspc node newest.marked.local -n newest.!automatic.local

# swap the current node and the biggest node
#super + g
	#bspc node -s biggest

#
# state/flags
#

# set the window state
#super + {t,shift + t,s,f}
#	bspc node -t {tiled,pseudo_tiled,floating,fullscreen}

super + f
      bspc node -t floating

super + t
      bspc node -t tiled

super + shift + f
      bspc node -t fullscreen

# set the node flags
super + ctrl + {m,x,y,z}
bspc node -g {marked,locked,sticky,private}

#
# focus/swap
#

# focus the node in the given direction
super + {_,shift + }{Left,Down,Up,Right}
	bspc node -{f,s} {west,south,north,east}

super + {_,shift + }{h,j,k,l}
	bspc node -{f,s} {west,south,north,east}

# focus the node for the given path jump
super + {p,b,comma,period}
	bspc node -f @{parent,brother,first,second}

# focus the next/previous node in the current desktop
super + {_,shift + }c
	bspc node -f {next,prev}.local

# focus the next/previous desktop in the current monitor
super + bracket{left,right}
	bspc desktop -f {prev,next}.local

# focus the last node/desktop
super + {grave,Tab}
      ./.config/bspwm/scripts/swap_windows.sh

# focus the older or newer node in the focus history
super + {o,i}
	bspc wm -h off; \
	bspc node {older,newer} -f; \
	bspc wm -h on

# focus or send to the given desktop
super + {_,shift + }{1-9,0}
	bspc {desktop -f,node -d} '^{1-9,10}' --follow

ctrl + alt + {Left,Right}
    bspc node -d {prev,next} -f

ctrl + alt + {h,l}
    bspc node -d {prev,next} -f
